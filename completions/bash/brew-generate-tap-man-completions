_brew_generate_tap_man_completions() {
  local cur="${COMP_WORDS[COMP_CWORD]}"
  case "${cur}" in
    -*)
      __brewcomp "
      --debug
      --help
      --no-exit-code
      --quiet
      --tap
      --verbose
      "
      return
      ;;
    *) ;;
  esac
}
